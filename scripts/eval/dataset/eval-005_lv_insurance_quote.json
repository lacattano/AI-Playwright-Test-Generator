{
  "id": "eval-005",
  "site": "lv_insurance",
  "base_url": "http://localhost:8767/mock_insurance_site.html",
  "title": "Get a car insurance quote for a Honda CR-V",
  "user_story": "As a new customer, I want to get a car insurance quote for my Honda CR-V so that I can insure my vehicle with LV.",
  "conditions": [
    "1. Create account with personal details (email, password, name, DOB, address)",
    "2. Select Car Insurance product",
    "3. Enter policy details with Standard scheme and start date",
    "4. Enter account holder driver details (license, years licensed, occupation)",
    "5. Add a vehicle via registration lookup (AB12CDE → Honda CR-V)",
    "6. Select Social, Domestic & Pleasure usage type",
    "7. Set No Claims Discount and overnight parking location",
    "8. Verify extras page displays estimated premium and compulsory excess",
    "9. Select payment method (Pay in Full) and submit quote",
    "10. Verify quote confirmation page with reference number and premium"
  ],
  "golden_resolutions": [
    {
      "criterion_index": 0,
      "placeholders": [
        { "action": "FILL", "description": "email address", "expected_locator": "#email", "tolerance_selectors": ["input[type='email']"], "expected_page": "" },
        { "action": "FILL", "description": "password", "expected_locator": "#password", "tolerance_selectors": ["input[type='password']"], "expected_page": "" },
        { "action": "FILL", "description": "first name", "expected_locator": "#firstName", "tolerance_selectors": [], "expected_page": "" },
        { "action": "FILL", "description": "last name", "expected_locator": "#lastName", "tolerance_selectors": [], "expected_page": "" },
        { "action": "FILL", "description": "postcode", "expected_locator": "#postcode", "tolerance_selectors": [], "expected_page": "" },
        { "action": "CLICK", "description": "Next button on account page", "expected_locator": "#accountNext", "tolerance_selectors": ["button:has-text('Next')"], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 1,
      "placeholders": [
        { "action": "CLICK", "description": "Car Insurance product card", "expected_locator": "#productCar", "tolerance_selectors": [".card-option[data-product='car']"], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 2,
      "placeholders": [
        { "action": "FILL", "description": "cover start date", "expected_locator": "#startDate", "tolerance_selectors": [], "expected_page": "" },
        { "action": "SELECT", "description": "Standard scheme", "expected_locator": "#scheme", "tolerance_selectors": [], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 3,
      "placeholders": [
        { "action": "FILL", "description": "driving license number", "expected_locator": "#mainLicenseNumber", "tolerance_selectors": [], "expected_page": "" },
        { "action": "FILL", "description": "years licensed", "expected_locator": "#mainLicenseYears", "tolerance_selectors": [], "expected_page": "" },
        { "action": "SELECT", "description": "occupation", "expected_locator": "#mainOccupation", "tolerance_selectors": [], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 4,
      "placeholders": [
        { "action": "FILL", "description": "vehicle registration number", "expected_locator": "#vehicleReg", "tolerance_selectors": [], "expected_page": "" },
        { "action": "CLICK", "description": "Look Up registration button", "expected_locator": "#lookupRegBtn", "tolerance_selectors": ["button:has-text('Look Up')"], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 5,
      "placeholders": [
        { "action": "CLICK", "description": "SDP usage type radio", "expected_locator": "input[name='usageType'][value='SDP']", "tolerance_selectors": [], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 6,
      "placeholders": [
        { "action": "FILL", "description": "no claims discount years", "expected_locator": "#ncdYears", "tolerance_selectors": [], "expected_page": "" },
        { "action": "SELECT", "description": "overnight parking location", "expected_locator": "#overnightLocation", "tolerance_selectors": [], "expected_page": "" },
        { "action": "CLICK", "description": "Add Vehicle button", "expected_locator": "#addVehicleBtn", "tolerance_selectors": ["button:has-text('Add Another Vehicle')"], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 7,
      "placeholders": [
        { "action": "ASSERT", "description": "estimated annual premium displayed", "expected_locator": "#premiumPrice", "tolerance_selectors": [".price-value"], "expected_page": "" },
        { "action": "ASSERT", "description": "compulsory excess information", "expected_locator": "#excessInfo", "tolerance_selectors": [], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 8,
      "placeholders": [
        { "action": "CLICK", "description": "Pay in Full payment option", "expected_locator": "#paymentFull", "tolerance_selectors": [".card-option:has-text('Pay in Full')"], "expected_page": "" },
        { "action": "CLICK", "description": "Submit and Get Quote button", "expected_locator": "#quoteSubmit", "tolerance_selectors": ["button:has-text('Submit')"], "expected_page": "" }
      ]
    },
    {
      "criterion_index": 9,
      "placeholders": [
        { "action": "ASSERT", "description": "quote generated successfully message", "expected_locator": "#quoteSuccess", "tolerance_selectors": ["h2:has-text('Quote Generated')"], "expected_page": "" },
        { "action": "ASSERT", "description": "quote reference number", "expected_locator": "#quoteRef", "tolerance_selectors": [], "expected_page": "" }
      ]
    }
  ]
}
